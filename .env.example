# Optional. When set, every /api request must include either:
#   x-api-token: <token>
# or:
#   Authorization: Bearer <token>
API_TOKEN=change-me-before-exposing-the-api

# Optional. Defaults to data/tasks.sqlite.
# Use an absolute path for production or shared deployments.
TASK_DB_PATH=/absolute/path/to/tasks.sqlite

# Optional. Defaults to 4010.
PORT=4010

# Optional. Required only when dispatching real 企业微信 self-built app messages.
# Create a self-built app in 企业微信管理后台, put target users in its visibility scope,
# then set these before running `npm run task -- message dispatch`.
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxx
WECOM_AGENT_SECRET=your-self-built-app-secret
WECOM_AGENT_ID=1000002

# Optional. launchd dispatch tuning.
MESSAGE_DISPATCH_LIMIT=20
