# Optional. When set, every /api request must include either:
#   x-api-token: <token>
# or:
#   Authorization: Bearer <token>
API_TOKEN=change-me-before-exposing-the-api

# Optional. Defaults to data/tasks.sqlite.
# Use an absolute path for production or shared deployments.
TASK_DB_PATH=/absolute/path/to/tasks.sqlite

# Optional. Defaults to 4010.
PORT=4010
