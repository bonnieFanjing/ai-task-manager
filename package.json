{
  "name": "ai-task-manager",
  "version": "0.1.0",
  "private": false,
  "description": "Local-first AI-friendly personal task manager with SQLite, CLI, API, and web UI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bonnieFanjing/ai-task-manager.git"
  },
  "bugs": {
    "url": "https://github.com/bonnieFanjing/ai-task-manager/issues"
  },
  "homepage": "https://github.com/bonnieFanjing/ai-task-manager#readme",
  "engines": {
    "node": ">=22.5.0"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "NODE_NO_WARNINGS=1 tsx watch src/server/index.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.server.json && vite build",
    "lint": "tsc -p tsconfig.check.json --noEmit",
    "test": "NODE_NO_WARNINGS=1 vitest run",
    "test:watch": "NODE_NO_WARNINGS=1 vitest",
    "test:e2e": "NODE_NO_WARNINGS=1 playwright test",
    "db:migrate": "NODE_NO_WARNINGS=1 tsx src/db/migrate.ts",
    "db:check": "NODE_NO_WARNINGS=1 tsx src/db/check.ts",
    "task": "NODE_NO_WARNINGS=1 tsx src/cli.ts",
    "ai:scan": "scripts/ai-scan-reminders.sh",
    "ai:scan:reminders": "AI_SCAN_SYNC_REMINDERS=1 scripts/ai-scan-reminders.sh",
    "ai:scan:install": "scripts/install-ai-scan-launchd.sh",
    "message:dispatch": "scripts/message-dispatch.sh",
    "message:dispatch:install": "scripts/install-message-dispatch-launchd.sh"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsx": "^4.21.0",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
